{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chestnut",
  "version": "0.3.0",
  "identifier": "dev.chestnut.app",
  "build": {
    "beforeDevCommand": "node scripts/ensure-vite-dev.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chestnut Editor",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "displayLanguageSelector": false
      }
    }
  }
}
