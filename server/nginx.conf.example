upstream boke_api {
    server 127.0.0.1:8787;
}

server {
    listen 443 ssl http2;
    server_name boke.example.com;

    # ssl_certificate /etc/letsencrypt/live/boke.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/boke.example.com/privkey.pem;

    root /var/www/boke/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://boke_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /attachments/ {
        proxy_pass http://boke_api;
        proxy_set_header Host $host;
    }
}

server {
    listen 80;
    server_name boke.example.com;
    return 301 https://$host$request_uri;
}
