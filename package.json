{
  "name": "boke",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first Markdown + Excalidraw knowledge manager",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @boke/desktop tauri dev -t x86_64-pc-windows-msvc",
    "build": "pnpm --filter @boke/desktop build",
    "build:desktop": "pnpm --filter @boke/desktop tauri build -t x86_64-pc-windows-msvc",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=20"
  }
}
